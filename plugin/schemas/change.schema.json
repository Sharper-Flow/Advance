{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/anomalyco/oc-plugins/advance/schemas/change.schema.json",
  "title": "ADV Change",
  "description": "ADV Change Proposal",
  "$ref": "#/definitions/change",
  "definitions": {
    "change": {
      "type": "object",
      "properties": {
        "$schema": {
          "type": "string"
        },
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "pending",
            "active",
            "archived"
          ]
        },
        "created_at": {
          "type": "string"
        },
        "created_by": {
          "type": "string"
        },
        "tasks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "section": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": [
                  "pending",
                  "in_progress",
                  "done",
                  "cancelled"
                ]
              },
              "priority": {
                "type": "number",
                "default": 0
              },
              "deps": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "enum": [
                        "blocked_by",
                        "related",
                        "discovered_from",
                        "parent"
                      ]
                    },
                    "target": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "type",
                    "target"
                  ],
                  "additionalProperties": false
                }
              },
              "created_at": {
                "type": "string"
              },
              "started_at": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "completed_at": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "completed_by": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "tdd_phase": {
                "type": "string",
                "enum": [
                  "none",
                  "red",
                  "green",
                  "refactor",
                  "complete"
                ],
                "default": "none"
              },
              "tdd_evidence": {
                "type": "object",
                "properties": {
                  "red": {
                    "type": "object",
                    "properties": {
                      "test_file": {
                        "type": "string"
                      },
                      "command": {
                        "type": "string"
                      },
                      "output_snippet": {
                        "type": "string"
                      },
                      "exit_code": {
                        "type": "number"
                      },
                      "recorded_at": {
                        "type": "string"
                      }
                    },
                    "additionalProperties": false
                  },
                  "green": {
                    "type": "object",
                    "properties": {
                      "test_file": {
                        "type": "string"
                      },
                      "command": {
                        "type": "string"
                      },
                      "output_snippet": {
                        "type": "string"
                      },
                      "exit_code": {
                        "type": "number"
                      },
                      "recorded_at": {
                        "type": "string"
                      }
                    },
                    "additionalProperties": false
                  },
                  "skipped": {
                    "type": "boolean"
                  },
                  "skip_reason": {
                    "type": "string"
                  }
                },
                "additionalProperties": false
              }
            },
            "required": [
              "id",
              "title",
              "status",
              "created_at"
            ],
            "additionalProperties": true
          }
        },
        "deltas": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "anyOf": [
                {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "operation": {
                      "type": "string",
                      "const": "add"
                    },
                    "requirement": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "title": {
                          "type": "string"
                        },
                        "body": {
                          "type": "string"
                        },
                        "priority": {
                          "type": "string",
                          "enum": [
                            "must",
                            "should",
                            "may"
                          ]
                        },
                        "tags": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        },
                        "scenarios": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "string"
                              },
                              "title": {
                                "type": "string"
                              },
                              "given": {
                                "type": "array",
                                "items": {
                                  "type": "string"
                                }
                              },
                              "when": {
                                "type": "string"
                              },
                              "then": {
                                "type": "array",
                                "items": {
                                  "type": "string"
                                }
                              }
                            },
                            "required": [
                              "id",
                              "title",
                              "given",
                              "when",
                              "then"
                            ],
                            "additionalProperties": true
                          }
                        }
                      },
                      "required": [
                        "id",
                        "title",
                        "body",
                        "priority"
                      ],
                      "additionalProperties": true
                    }
                  },
                  "required": [
                    "id",
                    "operation",
                    "requirement"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "operation": {
                      "type": "string",
                      "const": "modify"
                    },
                    "target_id": {
                      "type": "string"
                    },
                    "changes": {
                      "type": "object",
                      "additionalProperties": {}
                    }
                  },
                  "required": [
                    "id",
                    "operation",
                    "target_id",
                    "changes"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "operation": {
                      "type": "string",
                      "const": "remove"
                    },
                    "target_id": {
                      "type": "string"
                    },
                    "reason": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "id",
                    "operation",
                    "target_id",
                    "reason"
                  ],
                  "additionalProperties": false
                }
              ]
            }
          }
        },
        "validation": {
          "type": "object",
          "properties": {
            "checked_against_specs": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "conflicts": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "code": {
                    "type": "string"
                  },
                  "message": {
                    "type": "string"
                  },
                  "path": {
                    "type": "string"
                  },
                  "details": {
                    "type": "object",
                    "additionalProperties": {}
                  }
                },
                "required": [
                  "code",
                  "message"
                ],
                "additionalProperties": false
              }
            },
            "warnings": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "code": {
                    "type": "string"
                  },
                  "message": {
                    "type": "string"
                  },
                  "path": {
                    "type": "string"
                  }
                },
                "required": [
                  "code",
                  "message"
                ],
                "additionalProperties": false
              }
            },
            "validated_at": {
              "type": "string"
            }
          },
          "required": [
            "checked_against_specs",
            "conflicts",
            "warnings"
          ],
          "additionalProperties": false
        },
        "wisdom": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "type": {
                "type": "string",
                "enum": [
                  "pattern",
                  "success",
                  "failure",
                  "gotcha",
                  "convention"
                ]
              },
              "content": {
                "type": "string",
                "maxLength": 2000
              },
              "source_task": {
                "type": "string"
              },
              "recorded_at": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "type",
              "content",
              "recorded_at"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "id",
        "title",
        "status",
        "created_at",
        "tasks",
        "deltas"
      ],
      "additionalProperties": true
    }
  }
}
