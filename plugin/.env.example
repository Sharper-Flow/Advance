# ------------------------------------------------------------------
# ADV Plugin environment example
# ------------------------------------------------------------------
# This file documents environment variables understood by the plugin.
# Copy to `.env` and adjust as needed — nothing here is required when
# running against a loopback Temporal dev server.
# ------------------------------------------------------------------

# ------------------------------------------------------------------
# Temporal-backed storage (production path)
# ------------------------------------------------------------------
# Temporal durable execution is the production storage backend. The
# plugin bootstrap wires a Temporal client bundle into createStore()
# by default; the file-backed JSON+SQLite path is retained only as a
# dedicated test/dev harness (activated when no bundle is wired, or
# when ADV_DISABLE_TEMPORAL=1 is set).

# Temporal frontend address. Defaults to loopback dev server.
# Non-loopback hosts require ADV_TEMPORAL_ALLOW_REMOTE=true.
ADV_TEMPORAL_ADDRESS=127.0.0.1:7233

# Temporal namespace. Must match ^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$
ADV_TEMPORAL_NAMESPACE=default

# Explicit opt-in to allow ADV_TEMPORAL_ADDRESS outside 127.0.0.1/::1.
# Leave blank on developer machines.
# ADV_TEMPORAL_ALLOW_REMOTE=true

# Task queue the worker should subscribe to. Typically project-scoped
# via buildProjectTaskQueue(projectId). Only the worker process reads
# this variable directly.
# ADV_TEMPORAL_TASK_QUEUE=advance-<project-id>

# Internal use by runtime-manager when spawning a worker process. You
# normally do not set this yourself; it is populated by the plugin.
# ADV_TEMPORAL_PROJECT_ID=<project-id>

# Escape hatch: set to 1 to skip the Temporal bootstrap entirely and run
# the plugin on the file-backed test harness path. Intended for local
# development and tests only — production deployments must leave this unset.
# ADV_DISABLE_TEMPORAL=1

# ------------------------------------------------------------------
# OpenCode cache/runtime dirs (optional)
# ------------------------------------------------------------------
# The plugin prefers these directories for the Temporal runtime lock
# and other cache files. OPEN_CHAD_CACHE_DIR wins, then XDG_RUNTIME_DIR,
# then os.tmpdir().
# OPEN_CHAD_CACHE_DIR=/path/to/cache
# XDG_RUNTIME_DIR=/run/user/$UID
