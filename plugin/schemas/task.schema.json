{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/anomalyco/oc-plugins/advance/schemas/task.schema.json",
  "title": "ADV Task",
  "description": "ADV Task",
  "$ref": "#/definitions/task",
  "definitions": {
    "task": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "section": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "in_progress",
            "done",
            "cancelled"
          ]
        },
        "priority": {
          "type": "number",
          "default": 0
        },
        "deps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "blocked_by",
                  "related",
                  "discovered_from",
                  "parent"
                ]
              },
              "target": {
                "type": "string"
              }
            },
            "required": [
              "type",
              "target"
            ],
            "additionalProperties": false
          }
        },
        "created_at": {
          "type": "string"
        },
        "started_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "completed_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "completed_by": {
          "type": [
            "string",
            "null"
          ]
        },
        "tdd_phase": {
          "type": "string",
          "enum": [
            "none",
            "red",
            "green",
            "refactor",
            "complete"
          ],
          "default": "none"
        },
        "tdd_evidence": {
          "type": "object",
          "properties": {
            "red": {
              "type": "object",
              "properties": {
                "test_file": {
                  "type": "string"
                },
                "command": {
                  "type": "string"
                },
                "output_snippet": {
                  "type": "string"
                },
                "exit_code": {
                  "type": "number"
                },
                "recorded_at": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            },
            "green": {
              "type": "object",
              "properties": {
                "test_file": {
                  "type": "string"
                },
                "command": {
                  "type": "string"
                },
                "output_snippet": {
                  "type": "string"
                },
                "exit_code": {
                  "type": "number"
                },
                "recorded_at": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            },
            "skipped": {
              "type": "boolean"
            },
            "skip_reason": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      },
      "required": [
        "id",
        "title",
        "status",
        "created_at"
      ],
      "additionalProperties": true
    }
  }
}
