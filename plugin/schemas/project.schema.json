{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/anomalyco/oc-plugins/advance/schemas/project.schema.json",
  "title": "ADV Project",
  "description": "ADV Project Configuration",
  "$ref": "#/definitions/project",
  "definitions": {
    "project": {
      "type": "object",
      "properties": {
        "$schema": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "specs_dir": {
          "type": "string",
          "default": ".adv/specs"
        },
        "changes_dir": {
          "type": "string",
          "default": ".adv/changes"
        },
        "archive_dir": {
          "type": "string",
          "default": ".adv/archive"
        },
        "docs_dir": {
          "type": "string",
          "default": "docs/specs"
        },
        "db_dir": {
          "type": "string",
          "default": ".adv/db"
        },
        "project_file": {
          "type": "string",
          "default": "project.md"
        },
        "related_repos": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "role": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "path"
            ],
            "additionalProperties": false
          }
        },
        "features": {
          "type": "object",
          "properties": {
            "tdd_enforcement": {
              "type": "string",
              "enum": [
                "strict",
                "advisory",
                "off"
              ],
              "default": "strict"
            },
            "worktree_auto_create": {
              "type": "boolean",
              "default": true
            },
            "gate_enforcement": {
              "type": "string",
              "enum": [
                "strict",
                "advisory"
              ],
              "default": "strict"
            },
            "wisdom_accumulation": {
              "type": "boolean",
              "default": true
            }
          },
          "additionalProperties": true,
          "default": {}
        }
      },
      "required": [
        "name"
      ],
      "additionalProperties": true
    }
  }
}
