#!/usr/bin/env bash
# post-commit: auto-sync ADV assets to the global OpenCode config when the
# commit touches anything that the global install mirrors.
#
# Prevents the drift class this hook was created to fix: a commit lands in
# the repo but `~/.config/opencode/` still has the old command/agent/skill
# files, so agents invoking `/adv-*` from other repos see stale contracts.
#
# Behavior:
# - Silent no-op if the commit touched none of the synced paths.
# - Runs scripts/sync-global.sh --fix otherwise (idempotent, ~1s).
# - Never blocks the commit (post-commit fires after the commit is already
#   recorded, so a non-zero exit would only emit a warning).
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
SYNC_SCRIPT="$REPO_ROOT/scripts/sync-global.sh"

# Paths that sync-global mirrors to ~/.config/opencode. Keep in sync with
# scripts/sync-global.sh.
SYNCED_PATHS=(
  ".opencode/command/"
  ".opencode/agents/"
  ".opencode/overlays/"
  "ADV_INSTRUCTIONS.md"
  "skills/"
)

# Look at the diff introduced by HEAD (the commit that just landed).
CHANGED="$(git diff-tree --no-commit-id --name-only -r HEAD 2>/dev/null || true)"

if [[ -z "$CHANGED" ]]; then
  exit 0
fi

NEEDS_SYNC=0
for path in "${SYNCED_PATHS[@]}"; do
  if grep -qE "^${path}" <<< "$CHANGED"; then
    NEEDS_SYNC=1
    break
  fi
done

if [[ "$NEEDS_SYNC" -eq 0 ]]; then
  exit 0
fi

if [[ ! -x "$SYNC_SCRIPT" ]]; then
  echo "[adv-post-commit] scripts/sync-global.sh not found or not executable; skipping sync." >&2
  exit 0
fi

echo "[adv-post-commit] Synced ADV assets to the global OpenCode install (touched: $(echo "$CHANGED" | head -3 | tr '\n' ' '))"
"$SYNC_SCRIPT" --fix >/dev/null 2>&1 || {
  echo "[adv-post-commit] sync-global.sh failed; run manually:" >&2
  echo "  $SYNC_SCRIPT --fix" >&2
  exit 0
}
