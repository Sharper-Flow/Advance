#!/usr/bin/env bun
/**
 * adv — ADV (Advance) status CLI
 *
 * Read-only terminal client that reads ADV state from disk and prints
 * a formatted status table. No OpenCode session required.
 *
 * Runtime: Bun 1.3+
 * Dependencies: none (Bun built-ins + Node stdlib only)
 */

import { readdir } from "fs/promises";
import { join } from "path";
import { parseArgs } from "node:util";

import {
  listChanges,
  computeLastActivity,
  classifyRecency,
  buildGateProgress,
  firstIncompleteGate,
  countTasks,
  isDashboardActiveStatus,
} from "./lib/changes";
import {
  resolveProjectId,
  resolveExternalRoot,
  resolveRepoRoot,
} from "./lib/project";
import { shouldUseColor, formatTable, BOLD, DIM, RESET } from "./lib/render";
import type { ChangeSummary } from "./lib/types";
import { readSnapshotFile, renderRoadmap, roadmapJson } from "./lib/roadmap";

// =============================================================================
// Constants
// =============================================================================

const VERSION = "0.1.0";

// =============================================================================
// Subcommands
// =============================================================================

async function runStatus(noColor: boolean): Promise<number> {
  const cwd = process.cwd();
  const projectId = await resolveProjectId(cwd);
  if (!projectId) {
    process.stderr.write("error: not in a git repo (or git unavailable)\n");
    return 1;
  }

  const root = resolveExternalRoot(projectId);

  // Check state directory exists
  try {
    await readdir(root);
  } catch {
    process.stderr.write(
      `error: no ADV state for project ${projectId.slice(0, 8)}…\n`,
    );
    process.stderr.write(
      "       run /adv-status in an OpenCode session first.\n",
    );
    return 2;
  }

  const useColor = shouldUseColor(noColor);
  const now = new Date();

  // Collect active changes
  const summaries: ChangeSummary[] = [];
  let archivedCount = 0;
  let closedCount = 0;
  const activeDir = join(root, "changes");

  for await (const change of listChanges(activeDir)) {
    if (change.status === "archived") archivedCount++;
    else if (change.status === "closed") closedCount++;
    if (!isDashboardActiveStatus(change.status)) continue;

    const lastActivityAt = computeLastActivity(change);
    const activityDate = new Date(lastActivityAt);
    const minutesSinceActivity = Math.max(
      0,
      Math.floor((now.getTime() - activityDate.getTime()) / 60000),
    );
    const { done, total } = countTasks(change.tasks);

    summaries.push({
      id: change.id,
      title: change.title,
      status: change.status,
      recency: classifyRecency(minutesSinceActivity),
      lastActivityAt,
      minutesSinceActivity,
      tasksDone: done,
      tasksTotal: total,
      firstIncompleteGate: firstIncompleteGate(change.gates),
      gateProgressStr: buildGateProgress(change.gates),
      parentChangeId: change.fast_follow_of?.parent_change_id,
    });
  }

  // Sort by lastActivityAt descending
  summaries.sort((a, b) => b.lastActivityAt.localeCompare(a.lastActivityAt));

  // Count statuses for footer
  const archiveDir = join(root, "archive");
  for await (const change of listChanges(archiveDir)) {
    if (change.status === "archived") archivedCount++;
    else if (change.status === "closed") closedCount++;
  }

  // Header
  const shortId = projectId.slice(0, 8);
  const headerLine = useColor
    ? `${BOLD}ADV — ${shortId}…${RESET}`
    : `ADV — ${shortId}…`;

  const output: string[] = [];
  output.push(headerLine);
  output.push("");
  output.push(formatTable(summaries, useColor, now));
  output.push("");
  output.push(
    `${summaries.length} active · ${archivedCount} archived · ${closedCount} closed`,
  );

  process.stdout.write(output.join("\n") + "\n");
  return 0;
}

async function runRoadmap(
  noColor: boolean,
  json: boolean,
  kind: "bug" | "feature" | "all",
  top: number | undefined,
  priority: "critical" | "high" | "medium" | "low" | undefined,
): Promise<number> {
  const cwd = process.cwd();
  const repoRoot = await resolveRepoRoot(cwd);

  const result = await readSnapshotFile(repoRoot);
  if (!result.ok) {
    process.stderr.write(`error: ${result.error}\n`);
    process.stderr.write(`hint: ${result.hint}\n`);
    return 2;
  }

  const useColor = shouldUseColor(noColor);
  const now = new Date();

  if (json) {
    process.stdout.write(
      roadmapJson(result.snapshot, { kind, top, priority }, now) + "\n",
    );
  } else {
    process.stdout.write(
      renderRoadmap(result.snapshot, { kind, top, priority }, useColor, now),
    );
  }
  return 0;
}

function runHelp(): number {
  process.stdout.write(
    `adv — ADV (Advance) status CLI

USAGE:
  adv [SUBCOMMAND] [FLAGS]

SUBCOMMANDS:
  status      (default)  Show active changes table
  roadmap              Show prioritized backlog from file snapshot

FLAGS (global):
  -h, --help              Show this help
  -v, --version           Print version
      --no-color          Disable ANSI colors (also: NO_COLOR=1)

FLAGS (roadmap only):
      --json              Output JSON instead of rendered tables
      --kind {bug|feature|all}
                          Filter by item kind (default: all)
      --top <N>           Limit features to top N by WSJF
      --priority {critical|high|medium|low}
                          Filter bugs to a single priority tier

EXIT CODES:
  0  Success
  1  Not in a git repo, git failure, or unknown command
  2  No ADV state directory for this project (status)
     Roadmap snapshot missing (roadmap)

DOCS:
  https://github.com/Sharper-Flow/Advance
`,
  );
  return 0;
}

function runVersion(): number {
  process.stdout.write(`adv v${VERSION}\n`);
  return 0;
}

// =============================================================================
// Entrypoint
// =============================================================================

async function main(argv: string[]): Promise<number> {
  // Global parse to catch --help, --version, --no-color before subcommand dispatch
  const { values, positionals } = parseArgs({
    args: argv,
    options: {
      help: { type: "boolean", short: "h" },
      version: { type: "boolean", short: "v" },
      "no-color": { type: "boolean" },
    },
    allowPositionals: true,
    strict: false,
  });

  if (values.help) return runHelp();
  if (values.version) return runVersion();

  const subcommand = positionals[0] ?? "status";

  if (subcommand === "status") {
    return runStatus(values["no-color"] ?? false);
  }

  if (subcommand === "roadmap") {
    // Strict parse for roadmap flags only
    const roadmapArgv = argv.slice(1); // drop "roadmap" positional
    let rValues: Record<string, unknown>;
    try {
      const parsed = parseArgs({
        args: roadmapArgv,
        options: {
          "no-color": { type: "boolean" },
          json: { type: "boolean" },
          kind: { type: "string" },
          top: { type: "string" },
          priority: { type: "string" },
        },
        allowPositionals: false,
        strict: true,
      });
      rValues = parsed.values as Record<string, unknown>;
    } catch (err) {
      const msg = err instanceof Error ? err.message : String(err);
      process.stderr.write(`roadmap: ${msg}\n`);
      return 2;
    }

    const kindVal = rValues.kind;
    const validKind = ["bug", "feature", "all"] as const;
    const kind: "bug" | "feature" | "all" = validKind.includes(kindVal as any)
      ? (kindVal as any)
      : "all";
    if (kindVal !== undefined && !validKind.includes(kindVal as any)) {
      process.stderr.write(
        `roadmap: invalid --kind "${kindVal}". Use bug, feature, or all.\n`,
      );
      return 2;
    }

    const priorityVal = rValues.priority;
    const validPriority = ["critical", "high", "medium", "low"] as const;
    const priority: "critical" | "high" | "medium" | "low" | undefined =
      validPriority.includes(priorityVal as any)
        ? (priorityVal as any)
        : undefined;
    if (
      priorityVal !== undefined &&
      !validPriority.includes(priorityVal as any)
    ) {
      process.stderr.write(
        `roadmap: invalid --priority "${priorityVal}". Use critical, high, medium, or low.\n`,
      );
      return 2;
    }

    let top: number | undefined;
    if (rValues.top !== undefined) {
      const n = Number(rValues.top);
      if (!Number.isFinite(n) || n < 1 || !Number.isInteger(n)) {
        process.stderr.write(
          `roadmap: invalid --top "${rValues.top}". Use a positive integer.\n`,
        );
        return 2;
      }
      top = n;
    }

    return runRoadmap(
      (rValues["no-color"] as boolean) ?? false,
      (rValues.json as boolean) ?? false,
      kind,
      top,
      priority,
    );
  }

  process.stderr.write(`unknown command: ${subcommand}. See adv --help\n`);
  return 1;
}

main(process.argv.slice(2)).then((code) => {
  process.exit(code);
});
