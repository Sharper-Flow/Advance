{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/anomalyco/oc-plugins/advance/schemas/requirement.schema.json",
  "title": "ADV Requirement",
  "description": "ADV Requirement",
  "$ref": "#/definitions/requirement",
  "definitions": {
    "requirement": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "body": {
          "type": "string"
        },
        "priority": {
          "type": "string",
          "enum": [
            "must",
            "should",
            "may"
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scenarios": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "given": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "when": {
                "type": "string"
              },
              "then": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "required": [
              "id",
              "title",
              "given",
              "when",
              "then"
            ],
            "additionalProperties": true
          }
        }
      },
      "required": [
        "id",
        "title",
        "body",
        "priority"
      ],
      "additionalProperties": true
    }
  }
}
