{
  "name": "@goost/advance",
  "version": "0.5.1",
  "description": "Advance (ADV) - Spec-driven development plugin for OpenCode where specs become enforceable laws",
  "type": "module",
  "main": "src/index.ts",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sharper-Flow/Advance.git"
  },
  "homepage": "https://github.com/Sharper-Flow/Advance#readme",
  "bugs": {
    "url": "https://github.com/Sharper-Flow/Advance/issues"
  },
  "author": "Anomaly",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts && pnpm run generate:schemas",
    "dev": "tsup src/index.ts --format esm --watch",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format:check",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "generate:schemas": "pnpm dlx tsx scripts/generate-schemas.ts",
    "generate:docs": "pnpm dlx tsx scripts/generate-docs.ts",
    "migrate:add-schemas": "pnpm dlx tsx scripts/add-schema-refs.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@opencode-ai/plugin": "^1.1.34",
    "nanoid": "^5.0.9",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.5",
    "better-sqlite3": "^12.6.2",
    "bun-types": "^1.3.6",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.4.2",
    "tsup": "^8.5.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.56.0",
    "vitest": "^4.0.18",
    "zod-to-json-schema": "^3.25.1"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "src",
    "schemas"
  ],
  "keywords": [
    "opencode",
    "plugin",
    "specs",
    "requirements",
    "tdd",
    "spec-driven",
    "validation",
    "ai-agent",
    "mcp",
    "model-context-protocol"
  ],
  "license": "MIT",
  "overrides": {
    "minimatch": "^10.2.3",
    "ajv": "6.14.0",
    "rollup": "^4.59.0",
    "flatted": "3.4.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "minimatch": "^10.2.3",
      "ajv": "6.14.0",
      "rollup": "^4.59.0",
      "flatted": "3.4.1"
    }
  }
}
