{
  "$id": "https://raw.githubusercontent.com/Sharper-Flow/Advance/trunk/plugin/schemas/requirement.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": {},
  "properties": {
    "body": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "meta": {
      "additionalProperties": false,
      "properties": {
        "merged_from": {
          "type": "string"
        }
      },
      "required": [
        "merged_from"
      ],
      "type": "object"
    },
    "priority": {
      "enum": [
        "must",
        "should",
        "may"
      ],
      "type": "string"
    },
    "scenarios": {
      "items": {
        "additionalProperties": {},
        "properties": {
          "given": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "id": {
            "type": "string"
          },
          "then": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "title": {
            "type": "string"
          },
          "when": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "title",
          "given",
          "when",
          "then"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "tags": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "title": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "title",
    "body",
    "priority"
  ],
  "title": "ADV Requirement",
  "type": "object"
}
