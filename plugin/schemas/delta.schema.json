{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/anomalyco/oc-plugins/advance/schemas/delta.schema.json",
  "title": "ADV Delta",
  "description": "ADV Delta Operation",
  "$ref": "#/definitions/delta",
  "definitions": {
    "delta": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "operation": {
              "type": "string",
              "const": "add"
            },
            "requirement": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "body": {
                  "type": "string"
                },
                "priority": {
                  "type": "string",
                  "enum": [
                    "must",
                    "should",
                    "may"
                  ]
                },
                "tags": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "scenarios": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "title": {
                        "type": "string"
                      },
                      "given": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      "when": {
                        "type": "string"
                      },
                      "then": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    },
                    "required": [
                      "id",
                      "title",
                      "given",
                      "when",
                      "then"
                    ],
                    "additionalProperties": true
                  }
                }
              },
              "required": [
                "id",
                "title",
                "body",
                "priority"
              ],
              "additionalProperties": true
            }
          },
          "required": [
            "id",
            "operation",
            "requirement"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "operation": {
              "type": "string",
              "const": "modify"
            },
            "target_id": {
              "type": "string"
            },
            "changes": {
              "type": "object",
              "additionalProperties": {}
            }
          },
          "required": [
            "id",
            "operation",
            "target_id",
            "changes"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "id": {
              "type": "string"
            },
            "operation": {
              "type": "string",
              "const": "remove"
            },
            "target_id": {
              "type": "string"
            },
            "reason": {
              "type": "string"
            }
          },
          "required": [
            "id",
            "operation",
            "target_id",
            "reason"
          ],
          "additionalProperties": false
        }
      ]
    }
  }
}
