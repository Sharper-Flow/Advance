#!/usr/bin/env bun
/**
 * adv — ADV (Advance) status CLI
 *
 * Read-only terminal client. Status reads live Temporal state for active
 * changes; roadmap reads the generated file snapshot.
 *
 * Runtime: Bun 1.3+
 * Dependencies: Bun built-ins + plugin Temporal client dependencies.
 */

import { join } from "path";
import { parseArgs } from "node:util";

import { listChanges } from "./lib/changes";
import {
  resolveProjectId,
  resolveExternalRoot,
  resolveRepoRoot,
} from "./lib/project";
import {
  shouldUseColor,
  formatTable,
  BOLD,
  RESET,
  emitJson,
} from "./lib/render";
import { readSnapshotFile, renderRoadmap, roadmapJson } from "./lib/roadmap";
import { runSlopScan } from "./lib/slop-scan/scan";
import { renderSlopScanReport } from "./lib/slop-scan/render";
import {
  buildLiveStatusFailure,
  buildLiveStatusPayloadFromSummaries,
  filterTerminalSummaries,
  QUERY_TIMEOUT_MS,
  loadLiveSummaries,
} from "./lib/live-status";

// =============================================================================
// Constants
// =============================================================================

const VERSION = "0.1.0";

// =============================================================================
// Subcommands
// =============================================================================

async function countTerminalChanges(root: string): Promise<{
  archivedCount: number;
  closedCount: number;
  terminalChangeIds: Set<string>;
}> {
  let archivedCount = 0;
  let closedCount = 0;
  const terminalChangeIds = new Set<string>();
  const archiveDir = join(root, "archive");
  for await (const change of listChanges(archiveDir, { quiet: true })) {
    if (change.status === "archived") {
      archivedCount++;
      terminalChangeIds.add(change.id);
    } else if (change.status === "closed") {
      closedCount++;
      terminalChangeIds.add(change.id);
    }
  }
  return { archivedCount, closedCount, terminalChangeIds };
}

async function runStatus(noColor: boolean, json: boolean): Promise<number> {
  const cwd = process.cwd();
  const projectId = await resolveProjectId(cwd);
  if (!projectId) {
    const error = "not in a git repo (or git unavailable)";
    if (json) {
      process.stdout.write(
        emitJson({
          source: "temporal",
          live: false,
          stale: false,
          generated_at: new Date().toISOString(),
          project_id: null,
          counts: { active: 0, archived: 0, closed: 0 },
          changes: [],
          error,
          remediation: "Run adv status from inside a git repository.",
        }) + "\n",
      );
    } else {
      process.stderr.write(`error: ${error}\n`);
    }
    return 1;
  }

  const root = resolveExternalRoot(projectId);
  const useColor = shouldUseColor(noColor);
  const now = new Date();
  const rawTimeout = Number(process.env.ADV_STATUS_TIMEOUT_MS);
  const timeoutMs =
    Number.isFinite(rawTimeout) && rawTimeout > 0
      ? rawTimeout
      : QUERY_TIMEOUT_MS;

  try {
    const [summaries, terminalCounts] = await Promise.all([
      loadLiveSummaries(projectId, now, timeoutMs),
      countTerminalChanges(root),
    ]);
    const visibleSummaries = filterTerminalSummaries(
      summaries,
      terminalCounts.terminalChangeIds,
    );
    const payload = buildLiveStatusPayloadFromSummaries(visibleSummaries, {
      projectId,
      now,
      ...terminalCounts,
    });

    if (json) {
      process.stdout.write(emitJson(payload) + "\n");
      return 0;
    }

    const shortId = projectId.slice(0, 8);
    const headerLine = useColor
      ? `${BOLD}ADV — ${shortId}…${RESET}`
      : `ADV — ${shortId}…`;

    const output: string[] = [];
    output.push(headerLine);
    output.push("");
    output.push(formatTable(payload.changes, useColor, now));
    output.push("");
    output.push(
      `${payload.counts.active} active · ${payload.counts.archived} archived · ${payload.counts.closed} closed`,
    );

    process.stdout.write(output.join("\n") + "\n");
    return 0;
  } catch (err) {
    const failure = buildLiveStatusFailure(projectId, err, now);
    if (json) {
      process.stdout.write(emitJson(failure) + "\n");
    } else {
      process.stderr.write(`error: ${failure.error}\n`);
      process.stderr.write(`hint: ${failure.remediation}\n`);
    }
    return 2;
  }
}

async function runRoadmap(
  noColor: boolean,
  json: boolean,
  kind: "bug" | "feature" | "all",
  top: number | undefined,
  priority: "critical" | "high" | "medium" | "low" | undefined,
): Promise<number> {
  const cwd = process.cwd();
  const repoRoot = await resolveRepoRoot(cwd);

  const result = await readSnapshotFile(repoRoot);
  if (!result.ok) {
    process.stderr.write(`error: ${result.error}\n`);
    process.stderr.write(`hint: ${result.hint}\n`);
    return 2;
  }

  const useColor = shouldUseColor(noColor);
  const now = new Date();

  if (json) {
    process.stdout.write(
      roadmapJson(result.snapshot, { kind, top, priority }, now) + "\n",
    );
  } else {
    process.stdout.write(
      renderRoadmap(result.snapshot, { kind, top, priority }, useColor, now),
    );
  }
  return 0;
}

async function runSlopScanCommand(
  noColor: boolean,
  json: boolean,
  requestedPath: string,
): Promise<number> {
  const repoRoot = await resolveRepoRoot(process.cwd());
  const report = await runSlopScan({ repoRoot, requestedPath });
  if (json) process.stdout.write(emitJson(report) + "\n");
  else
    process.stdout.write(renderSlopScanReport(report, shouldUseColor(noColor)));
  return 0;
}

function runHelp(): number {
  process.stdout.write(
    `adv — ADV (Advance) status CLI

USAGE:
  adv [SUBCOMMAND] [FLAGS]

SUBCOMMANDS:
  status      (default)  Show active changes table
  roadmap              Show prioritized backlog from file snapshot
  slop-scan            Run deterministic slop scanner

FLAGS (global):
  -h, --help              Show this help
  -v, --version           Print version
      --no-color          Disable ANSI colors (also: NO_COLOR=1)
      --json              Output JSON for status, roadmap, or slop-scan

FLAGS (roadmap only):
      --kind {bug|feature|all}
                          Filter by item kind (default: all)
      --top <N>           Limit features to top N by WSJF
      --priority {critical|high|medium|low}
                          Filter bugs to a single priority tier

EXIT CODES:
  0  Success
  1  Not in a git repo, git failure, or unknown command
  2  Live Temporal status unavailable (status)
     Roadmap snapshot missing (roadmap)

DOCS:
  https://github.com/Sharper-Flow/Advance
`,
  );
  return 0;
}

function runVersion(): number {
  process.stdout.write(`adv v${VERSION}\n`);
  return 0;
}

// =============================================================================
// Entrypoint
// =============================================================================

async function main(argv: string[]): Promise<number> {
  // Global parse to catch --help, --version, --no-color before subcommand dispatch
  const { values, positionals } = parseArgs({
    args: argv,
    options: {
      help: { type: "boolean", short: "h" },
      version: { type: "boolean", short: "v" },
      "no-color": { type: "boolean" },
    },
    allowPositionals: true,
    strict: false,
  });

  if (values.help) return runHelp();
  if (values.version) return runVersion();

  const subcommand = positionals[0] ?? "status";

  if (subcommand === "status") {
    const statusArgv = positionals[0] === "status" ? argv.slice(1) : argv;
    let sValues: Record<string, unknown>;
    try {
      const parsed = parseArgs({
        args: statusArgv,
        options: {
          "no-color": { type: "boolean" },
          json: { type: "boolean" },
        },
        allowPositionals: false,
        strict: true,
      });
      sValues = parsed.values as Record<string, unknown>;
    } catch (err) {
      const msg = err instanceof Error ? err.message : String(err);
      process.stderr.write(`status: ${msg}\n`);
      return 2;
    }
    return runStatus(
      (sValues["no-color"] as boolean) ?? false,
      (sValues.json as boolean) ?? false,
    );
  }

  if (subcommand === "roadmap") {
    // Strict parse for roadmap flags only
    const roadmapArgv = argv.slice(1); // drop "roadmap" positional
    let rValues: Record<string, unknown>;
    try {
      const parsed = parseArgs({
        args: roadmapArgv,
        options: {
          "no-color": { type: "boolean" },
          json: { type: "boolean" },
          kind: { type: "string" },
          top: { type: "string" },
          priority: { type: "string" },
        },
        allowPositionals: false,
        strict: true,
      });
      rValues = parsed.values as Record<string, unknown>;
    } catch (err) {
      const msg = err instanceof Error ? err.message : String(err);
      process.stderr.write(`roadmap: ${msg}\n`);
      return 2;
    }

    const kindVal = rValues.kind;
    const validKind = ["bug", "feature", "all"] as const;
    const kind: "bug" | "feature" | "all" = validKind.includes(kindVal as any)
      ? (kindVal as any)
      : "all";
    if (kindVal !== undefined && !validKind.includes(kindVal as any)) {
      process.stderr.write(
        `roadmap: invalid --kind "${kindVal}". Use bug, feature, or all.\n`,
      );
      return 2;
    }

    const priorityVal = rValues.priority;
    const validPriority = ["critical", "high", "medium", "low"] as const;
    const priority: "critical" | "high" | "medium" | "low" | undefined =
      validPriority.includes(priorityVal as any)
        ? (priorityVal as any)
        : undefined;
    if (
      priorityVal !== undefined &&
      !validPriority.includes(priorityVal as any)
    ) {
      process.stderr.write(
        `roadmap: invalid --priority "${priorityVal}". Use critical, high, medium, or low.\n`,
      );
      return 2;
    }

    let top: number | undefined;
    if (rValues.top !== undefined) {
      const n = Number(rValues.top);
      if (!Number.isFinite(n) || n < 1 || !Number.isInteger(n)) {
        process.stderr.write(
          `roadmap: invalid --top "${rValues.top}". Use a positive integer.\n`,
        );
        return 2;
      }
      top = n;
    }

    return runRoadmap(
      (rValues["no-color"] as boolean) ?? false,
      (rValues.json as boolean) ?? false,
      kind,
      top,
      priority,
    );
  }

  if (subcommand === "slop-scan") {
    const slopArgv = argv.slice(1);
    let slopValues: Record<string, unknown>;
    let slopPositionals: string[];
    try {
      const parsed = parseArgs({
        args: slopArgv,
        options: {
          "no-color": { type: "boolean" },
          json: { type: "boolean" },
        },
        allowPositionals: true,
        strict: true,
      });
      slopValues = parsed.values as Record<string, unknown>;
      slopPositionals = parsed.positionals;
    } catch (err) {
      const msg = err instanceof Error ? err.message : String(err);
      process.stderr.write(`slop-scan: ${msg}\n`);
      return 2;
    }

    return runSlopScanCommand(
      (slopValues["no-color"] as boolean) ?? false,
      (slopValues.json as boolean) ?? false,
      slopPositionals[0] ?? ".",
    );
  }

  process.stderr.write(`unknown command: ${subcommand}. See adv --help\n`);
  return 1;
}

main(process.argv.slice(2)).then((code) => {
  process.exit(code);
});
