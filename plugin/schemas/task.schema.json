{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/anomalyco/oc-plugins/advance/schemas/task.schema.json",
  "title": "ADV Task",
  "description": "ADV Task",
  "$ref": "#/definitions/task",
  "definitions": {
    "task": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "code",
            "docs",
            "ops",
            "research",
            "approval",
            "verification"
          ],
          "default": "code"
        },
        "section": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "pending",
            "in_progress",
            "done",
            "cancelled"
          ]
        },
        "priority": {
          "type": "number",
          "default": 0
        },
        "deps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "blocked_by",
                  "related",
                  "discovered_from",
                  "parent"
                ]
              },
              "target": {
                "type": "string"
              }
            },
            "required": [
              "type",
              "target"
            ],
            "additionalProperties": false
          }
        },
        "created_at": {
          "type": "string"
        },
        "started_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "completed_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "completed_by": {
          "type": [
            "string",
            "null"
          ]
        },
        "tdd_phase": {
          "type": "string",
          "enum": [
            "none",
            "red",
            "green",
            "refactor",
            "complete"
          ],
          "default": "none"
        },
        "tdd_evidence": {
          "type": "object",
          "properties": {
            "red": {
              "type": "object",
              "properties": {
                "test_file": {
                  "type": "string"
                },
                "command": {
                  "type": "string"
                },
                "output_snippet": {
                  "type": "string"
                },
                "exit_code": {
                  "type": "number"
                },
                "recorded_at": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            },
            "green": {
              "type": "object",
              "properties": {
                "test_file": {
                  "type": "string"
                },
                "command": {
                  "type": "string"
                },
                "output_snippet": {
                  "type": "string"
                },
                "exit_code": {
                  "type": "number"
                },
                "recorded_at": {
                  "type": "string"
                }
              },
              "additionalProperties": false
            },
            "skipped": {
              "type": "boolean"
            },
            "skip_reason": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "target_repo": {
          "type": "string"
        },
        "target_path": {
          "type": "string"
        },
        "cancellation": {
          "type": "object",
          "properties": {
            "reason": {
              "type": "string"
            },
            "approved_by_user": {
              "type": "boolean",
              "const": true
            },
            "approval_evidence": {
              "type": "string"
            },
            "superseded_by": {
              "type": "string"
            },
            "approved_at": {
              "type": "string"
            }
          },
          "required": [
            "reason",
            "approved_by_user",
            "approval_evidence",
            "approved_at"
          ],
          "additionalProperties": false
        },
        "tdd_reclassification": {
          "type": "object",
          "properties": {
            "from_intent": {
              "type": "string"
            },
            "to_intent": {
              "type": "string",
              "enum": [
                "inline",
                "separate_verification",
                "not_applicable"
              ]
            },
            "reason": {
              "type": "string"
            },
            "approved_by_user": {
              "type": "boolean",
              "const": true
            },
            "approval_evidence": {
              "type": "string"
            },
            "approved_at": {
              "type": "string"
            }
          },
          "required": [
            "from_intent",
            "to_intent",
            "reason",
            "approved_by_user",
            "approval_evidence",
            "approved_at"
          ],
          "additionalProperties": false
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "error_recovery": {
          "type": "object",
          "properties": {
            "last_error": {
              "type": "string"
            },
            "retry_count": {
              "type": "integer",
              "minimum": 0
            },
            "max_retries": {
              "type": "integer",
              "minimum": 0
            },
            "error_class": {
              "type": "string",
              "enum": [
                "TRANSIENT",
                "SEMANTIC",
                "ENVIRONMENTAL",
                "FATAL"
              ]
            },
            "next_strategy": {
              "type": "string"
            }
          },
          "required": [
            "last_error",
            "retry_count",
            "max_retries",
            "error_class"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "id",
        "title",
        "status",
        "created_at"
      ],
      "additionalProperties": true
    }
  }
}
