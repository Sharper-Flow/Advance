{
  "name": "@goost/advance",
  "version": "0.6.0",
  "description": "Advance (ADV) - Spec-driven development plugin for OpenCode where specs become enforceable laws",
  "type": "module",
  "main": "src/index.ts",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sharper-Flow/Advance.git"
  },
  "homepage": "https://github.com/Sharper-Flow/Advance#readme",
  "bugs": {
    "url": "https://github.com/Sharper-Flow/Advance/issues"
  },
  "author": "Anomaly",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "dev": "tsup src/index.ts --format esm --watch",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format:check",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@opencode-ai/plugin": "latest",
    "nanoid": "^5.0.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "better-sqlite3": "^12.6.2",
    "bun-types": "^1.3.12",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.8.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "@vitest/coverage-v8": "^4.1.4",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "typescript": "^5.0.0 || ^6.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "src",
    "schemas"
  ],
  "keywords": [
    "opencode",
    "plugin",
    "specs",
    "requirements",
    "tdd",
    "spec-driven",
    "validation",
    "ai-agent",
    "mcp",
    "model-context-protocol"
  ],
  "license": "MIT",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "minimatch": "^10.2.3",
      "ajv": "6.14.0",
      "rollup": "^4.59.0",
      "flatted": ">=3.4.2",
      "vite": ">=8.0.5",
      "picomatch": ">=4.0.4",
      "brace-expansion": ">=5.0.5"
    }
  }
}
