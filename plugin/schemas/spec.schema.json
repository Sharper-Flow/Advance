{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/anomalyco/oc-plugins/advance/schemas/spec.schema.json",
  "title": "ADV Spec",
  "description": "ADV Specification (The Law)",
  "$ref": "#/definitions/spec",
  "definitions": {
    "spec": {
      "type": "object",
      "properties": {
        "$schema": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "updated_at": {
          "type": "string"
        },
        "requirements": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "body": {
                "type": "string"
              },
              "priority": {
                "type": "string",
                "enum": [
                  "must",
                  "should",
                  "may"
                ]
              },
              "tags": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "scenarios": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "title": {
                      "type": "string"
                    },
                    "given": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "when": {
                      "type": "string"
                    },
                    "then": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  },
                  "required": [
                    "id",
                    "title",
                    "given",
                    "when",
                    "then"
                  ],
                  "additionalProperties": true
                }
              }
            },
            "required": [
              "id",
              "title",
              "body",
              "priority"
            ],
            "additionalProperties": true
          }
        }
      },
      "required": [
        "name",
        "title",
        "purpose",
        "version",
        "updated_at",
        "requirements"
      ],
      "additionalProperties": true
    }
  }
}
